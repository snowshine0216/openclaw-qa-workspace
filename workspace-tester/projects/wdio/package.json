{
    "name": "wdio",
    "version": "1.0.0",
    "description": "Library Web E2E Test Automation with WebdriverIO",
    "scripts": {
        "allure-report": "npm run gen-allure-report && allure open ./reports/allure-report",
        "gen-allure-report": "allure generate ./reports/allure-raw --clean -o ./reports/allure-report",
        "wdio": "cross-env MAX_INSTANCES=2 RETRY=1 wdio run ./wdio.conf.ts --specKind demo",
        "ci": "cross-env RETRY=2 HEADLESS=1 wdio run ./wdio.conf.ts --specKind pre-checkin --glob 'specs/pre-checkin/*/*.spec.js'",
        "ci-beta": "cross-env RETRY=2 HEADLESS=1 wdio run ./wdio.conf.ts --specKind pre-checkin-beta --glob 'specs/beta/*/*.spec.js'",
        "wdio-raw": "wdio run ./wdio.conf.ts",
        "wdioteams": "cross-env RETRY=2 wdio run ./wdioteams.conf.ts --specKind regression --teams=desktop",
        "wdioteamsperf": "cross-env RETRY=0 wdio run ./wdioteams.conf.ts --specKind performance --teams=desktop",
        "wdioteamsweb": "cross-env RETRY=2 MAX_INSTANCES=2 wdio run ./wdioteams.conf.ts --specKind regression --teams=web",
        "infra": "cross-env RETRY=0 wdio run ./wdio.conf.ts --specKind infra-test",
        "ios": "cross-env FOR_IOS=1 HEADLESS=1 wdio run ./wdio.conf.ts --glob 'specs/ios/getInsightFileList.spec.js'",
        "pre-checkin": "wdio run ./wdio.conf.ts --specKind pre-checkin --glob 'specs/pre-checkin/*/*.spec.js'",
        "regression": "cross-env RETRY=0 wdio run ./wdio.conf.ts --specKind regression",
        "regression-premerge": "cross-env RETRY=2 wdio run ./wdio.conf.ts --specKind regression --spectre.url='http://10.23.38.50:3000'",
        "regression-edge": "wdio run ./wdio.conf.ts --specKind regression",
        "regression-ABA": "cross-env RETRY=2 HEADLESS=1 wdio run ./wdio.conf.ts --specKind regression",
        "regression-web": "cross-env MAX_INSTANCES=2 RETRY=2 HEADLESS=1 wdio run ./wdio.conf.ts --specKind web_regression",
        "regression-CI": "cross-env RETRY=2 MAX_INSTANCES=2 HEADLESS=1 wdio run ./wdio.conf.ts --specKind regression",
        "regression-CI-HQ": "cross-env MAX_INSTANCES=2 RETRY=2 HEADLESS=1 wdio run ./wdio.conf.ts --specKind regression-hq",
        "regression-hq": "wdio run ./wdio.conf.ts --specKind regression-hq",
        "regression-perf": "cross-env NODE_OPTIONS=\"--max_old_space_size=8192\" RETRY=0 MAX_INSTANCES=1 wdio run ./wdio.conf.ts --specKind performance",
        "premerge-customapp-CI": "cross-env HEADLESS=1 wdio run ./wdio.conf.ts --specKind regression --xml specs/regression/config/premerge/CustomApp_all.config.xml",
        "premerge-sharewithacl-CI": "cross-env HEADLESS=1 wdio run ./wdio.conf.ts --specKind regression --xml specs/regression/config/premerge/ShareWithACL.config.xml",
        "premerge-aibot-CI": "HEADLESS=1 wdio run ./wdio.conf.ts --specKind regression --xml specs/regression/config/premerge/AIBot.config.xml",
        "premerge-regression-aibot-CI": "HEADLESS=1 RETRY=2 wdio run ./wdio.conf.ts --specKind regression --glob 'specs/regression/*bot*/*.spec.js'",
        "premerge-regression-autoanswer-CI": "HEADLESS=1 RETRY=2 wdio run ./wdio.conf.ts --specKind regression --glob 'specs/regression/*AutoAnswer*/*.spec.js'",
        "premerge-regression-allAI-CI": "HEADLESS=1 RETRY=2 wdio run ./wdio.conf.ts --specKind regression --glob 'specs/regression/*{bot,AutoAnswer}*/*.spec.js'",
        "premerge-aibot-aiservice-CI": "HEADLESS=1 wdio run ./wdio.conf.ts --specKind regression --xml specs/regression/config/premerge/AIBot_AIPreMege.config.xml",
        "postinstall": "npm run update-chromedriver && patch-package",
        "update-chromedriver": "node ./node_modules/chromedriver/install.js",
        "eslint": "eslint . --fix",
        "prettier": "prettier --check --write .",
        "ts-check": "tsc --noEmit --skipLibCheck",
        "coverage-report": "nyc report --reporter=html --exclude-after-remap false"
    },
    "type": "module",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@types/babel__traverse": "^7.20.6",
        "@types/fs-extra": "^11.0.1",
        "@types/jasmine": "^4.3.5",
        "@types/proper-lockfile": "^4.1.2",
        "@types/uuid": "^9.0.8",
        "@types/yargs": "^17.0.24",
        "@typescript-eslint/eslint-plugin": "^6.2.1",
        "@typescript-eslint/parser": "^6.2.1",
        "@wdio/allure-reporter": "^8.11.0",
        "@wdio/cli": "8.32.2",
        "@wdio/codemod": "^0.12.0",
        "@wdio/devtools-service": "^8.38.2",
        "@wdio/jasmine-framework": "^8.11.0",
        "@wdio/local-runner": "^8.11.0",
        "@wdio/logger": "^8.11.0",
        "@wdio/spec-reporter": "^8.11.0",
        "@wdio/visual-service": "^5.0.1",
        "allure-commandline": "^2.21.0",
        "axios": "^1.4.0",
        "chalk": "^5.2.0",
        "chromedriver": "^121.0.2",
        "eslint": "^8.46.0",
        "eslint-config-prettier": "^8.9.0",
        "eslint-plugin-import": "^2.28.0",
        "eslint-plugin-prettier": "^5.0.0",
        "get-port": "^7.0.0",
        "googleapis": "^39.2.0",
        "jscodeshift": "^0.15.0",
        "p-iteration": "^1.1.8",
        "pako": "^2.1.0",
        "pg": "^8.3.3",
        "prettier": "^3.0.0",
        "ps-list": "^8.1.1",
        "socket.io": "^2.3.0",
        "socket.io-client": "^2.3.0",
        "ts-node": "^10.9.1",
        "typescript": "^4.9.5",
        "wdio-chromedriver-service": "^8.1.1",
        "wdio-coverage-service": "^1.0.2",
        "wdio-safaridriver-service": "^2.1.1",
        "wdio-video-reporter": "4.0.3",
        "wdio-wait-for": "^3.0.4"
    },
    "dependencies": {
        "@axe-core/webdriverio": "^4.8.3",
        "@babel/parser": "^7.26.8",
        "@babel/traverse": "^7.26.8",
        "@elastic.io/ntlm-client": "1.0.0",
        "@mstr/pdf-diff": "^2.1.2",
        "@pixdif/core": "^0.10.0",
        "@pixdif/model": "^0.10.0",
        "@pixdif/pdf-parser": "^0.10.0",
        "@reportportal/agent-js-webdriverio": "^5.2.0",
        "cheerio": "^1.0.0-rc.12",
        "ci-info": "^3.8.0",
        "clipboard-sys": "^1.2.1",
        "cross-env": "^7.0.3",
        "deepmerge": "^4.3.1",
        "fs-extra": "^11.1.1",
        "glob": "^10.3.3",
        "lodash": "^4.17.21",
        "moment": "^2.29.4",
        "mssql": "^11.0.1",
        "node-fetch": "^3.3.1",
        "nyc": "^15.1.0",
        "papaparse": "^5.5.3",
        "patch-package": "^8.0.0",
        "path": "^0.12.7",
        "proper-lockfile": "^4.1.2",
        "request": "^2.88.2",
        "ssl-root-cas": "^1.3.1",
        "urllib": "^2.44.0",
        "uuid": "^9.0.1",
        "xlsx": "^0.20.0",
        "yargs": "^17.7.2"
    }
}
