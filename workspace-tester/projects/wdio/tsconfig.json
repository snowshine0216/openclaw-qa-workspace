{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        // "explainFiles": true,
        "module": "node16",
        "target": "es2021",
        "allowJs": true,
        "noEmit": true,
        // comment out the following line because we use web-dossier's ESLint which uses an old version of typescript-eslint that doesn't support this option
        // "allowImportingTsExtensions": true,
        "strictNullChecks": true,
        "types": [
            "node",
            "@wdio/globals/types",
            "@wdio/jasmine-framework",
            "./globals",
            "./wdioServices/since",
            "./wdioServices/spectre"
        ],
    },
    "include": [
        // "*/**/*.ts",
        // "*/**/*.js",
        "./specs/**/*.spec.js",
    ],
}
