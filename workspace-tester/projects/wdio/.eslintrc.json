{
    "root": true,
    "env": {
        "node": true,
        "es2023": true
    },
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        // find the tsconfig.json nearest each source file
        "project": true
    },
    "plugins": ["import", "@typescript-eslint"],
    "extends": [
        "eslint:recommended",
        "plugin:import/recommended",
        "plugin:@typescript-eslint/recommended",
        // For legacy reasons, there are too many js content in this project
        // "plugin:@typescript-eslint/recommended-type-checked",
        "plugin:prettier/recommended"
    ],
    "rules": {
        // For legacy reasons, there are too many invalid jsdoc.
        "valid-jsdoc": "off",
        // Typescript is better to check global variables
        "no-undef": "off",

        // Due to that nodejs ESM requires file extension, while using typescript we can only specify *.js as extension
        "import/no-unresolved": "off",
        "import/extensions": ["error", "ignorePackages"],

        "@typescript-eslint/no-floating-promises": "error",
        "@typescript-eslint/no-unused-vars": "warn"
    }
}
