#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SOURCE_DIR="${REPO_ROOT}/.agents/skills"
TARGET_DIR="${HOME}/.openclaw/skills"

log() {
  printf '%s\n' "$1"
}

require_directory() {
  local path="$1"
  local label="$2"

  if [ ! -d "$path" ]; then
    log "error: ${label} not found: ${path}"
    exit 1
  fi
}

link_skill() {
  local source_path="$1"
  local skill_name
  local target_path

  skill_name="$(basename "$source_path")"
  target_path="${TARGET_DIR}/${skill_name}"

  if [ -e "$target_path" ] && [ ! -L "$target_path" ]; then
    rm -rf "$target_path"
    log "removed stale copy: ${skill_name}"
  fi

  ln -sfn "$source_path" "$target_path"
  log "linked: ${skill_name}"
}

main() {
  require_directory "$SOURCE_DIR" "source skills directory"
  mkdir -p "$TARGET_DIR"

  local linked_count=0
  local source_path

  for source_path in "$SOURCE_DIR"/*; do
    [ -d "$source_path" ] || continue
    link_skill "$source_path"
    linked_count=$((linked_count + 1))
  done

  log "done: linked ${linked_count} skill(s) from ${SOURCE_DIR} to ${TARGET_DIR}"
}

main "$@"
