# Jira CLI credentials
# Copy to .env in this same folder and fill in your values:
#   cp .env.example .env
#
# Resolution order (first found wins):
# 1. JIRA_ENV_FILE=/path/to/your.env
# 2. This skill folder (same dir as SKILL.md)
# 3. Workspace root .env
# 4. Repo root .env

JIRA_API_TOKEN=your-atlassian-api-token
JIRA_BASE_URL=https://your-domain.atlassian.net
# Optional: JIRA_USER_EMAIL for mention resolution (or use JIRA_LOGIN)
