22":{"self":"https://strategyagile.atlassian.net/rest/api/3/version/11276","id":"11276","name":"26.04","archived":false,"released":false,"releaseDate":"2026-04-17"},"customfield_10654":null,"customfield_10016":null,"customfield_10655":null,"customfield_10017":"yellow","customfield_10656":null,"customfield_10019":"0|i0tmmf:","customfield_10657":null,"updated":"2026-03-19T06:24:00.810-0400","customfield_10091":{"self":"https://strategyagile.atlassian.net/rest/api/3/customFieldOption/10120","value":"No","id":"10120"},"timeoriginalestimate":null,"description":{"type":"doc","version":1,"content":[{"type":"heading","attrs":{"level":3,"localId":"ce4ec53ce7fb"},"content":[{"type":"text","text":"Summary"}]},{"type":"paragraph","content":[{"type":"text","text":"The multi-selection search box design has usability issues. Users cannot confirm their selection with an \"OK\" button, leading to both functional and performance problems."}],"attrs":{"localId":"b65fc0955213"}},{"type":"heading","attrs":{"level":3,"localId":"3b0ce3b5f040"},"content":[{"type":"text","text":"Context"}]},{"type":"paragraph","content":[{"type":"text","text":"The current design relies on a 1-second debounce for multi-selection. This causes issues when users scroll through long lists and try to select more elements. The popover may dismiss unexpectedly if the selection is still loading."}],"attrs":{"localId":"870018ad6694"}},{"type":"heading","attrs":{"level":3,"localId":"6a60ea20a935"},"content":[{"type":"text","text":"Acceptance criteria"}]},{"type":"bulletList","content":[{"type":"listItem","attrs":{"localId":"938cfe44e868"},"content":[{"type":"paragraph","content":[{"type":"text","text":"Implement an \"OK\" button for users to confirm their selection."}],"attrs":{"localId":"d8f1b2faa638"}}]},{"type":"listItem","attrs":{"localId":"4ef1cc09f939"},"content":[{"type":"paragraph","content":[{"type":"text","text":"Ensure the popover does not dismiss unexpectedly during selection."}],"attrs":{"localId":"317599b23575"}}]},{"type":"listItem","attrs":{"localId":"28c7bb8a96d0"},"content":[{"type":"paragraph","content":[{"type":"text","text":"Improve performance for loading selections in long lists."}],"attrs":{"localId":"4f6427f48119"}}]}],"attrs":{"localId":"1777effaa57f"}},{"type":"heading","attrs":{"level":3,"localId":"d098f2055d8e"},"content":[{"type":"text","text":"Other information"}]},{"type":"paragraph","content":[{"type":"text","text":"N/A"}],"attrs":{"localId":"c0e0d02ddb73"}}]},"customfield_10130":10.0,"customfield_10131":null,"customfield_10010":null,"customfield_10132":{"self":"https://strategyagile.atlassian.net/rest/api/3/customFieldOption/10286","value":"In Refinement","id":"10286"},"customfield_10011":null,"customfield_10012":{"self":"https://strategyagile.atlassian.net/rest/api/3/customFieldOption/10016","value":"To Do","id":"10016"},"customfield_10133":{"self":"https://strategyagile.atlassian.net/rest/api/3/customFieldOption/10175","value":"Yes","id":"10175"},"customfield_10013":"ghx-label-3","customfield_10652":null,"customfield_10014":null,"customfield_10015":null,"customfield_10653":null,"customfield_10126":null,"customfield_10127":null,"customfield_10128":null,"customfield_10129":null,"attachment":[],"summary":"Enhanced search box selector for better multi-selection usability","customfield_10001":null,"customfield_10002":[],"customfield_10520":{"self":"https://strategyagile.atlassian.net/rest/api/3/user?accountId=557058%3Af1aadaf6-0464-4c4b-918e-d2527198eb40","accountId":"557058:f1aadaf6-0464-4c4b-918e-d2527198eb40","emailAddress":"yaolli@microstrategy.com","avatarUrls":{"48x48":"https://avatar-management--avatars.us-west-2.prod.public.atl-paas.net/557058:f1aadaf6-0464-4c4b-918e-d2527198eb40/b2ca5232-9f5d-4e90-b56a-00c9d1312652/48","24x24":"https://avatar-management--avatars.us-west-2.prod.public.atl-paas.net/557058:f1aadaf6-0464-4c4b-918e-d2527198eb40/b2ca5232-9f5d-4e90-b56a-00c9d1312652/24","16x16":"https://avatar-management--avatars.us-west-2.prod.p