{
  "name": "qa-plan-orchestrator-skill",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs scripts/test/*.test.mjs && bash scripts/test/run-all.sh",
    "benchmark:iteration0:prepare": "node benchmarks/qa-plan-v1/scripts/run_iteration0.mjs --prepare-only",
    "benchmark:iteration0:aggregate": "node benchmarks/qa-plan-v1/scripts/run_iteration0.mjs --aggregate-only",
    "benchmark:iteration0:seed-validate": "node benchmarks/qa-plan-v1/scripts/run_iteration0.mjs --seed-validate --executor-model gpt-5.4 --reasoning-effort high",
    "benchmark:v2:prepare": "node benchmarks/qa-plan-v2/scripts/run_baseline.mjs --prepare-only --executor-model gpt-5.4 --reasoning-effort high",
    "benchmark:v2:aggregate": "node benchmarks/qa-plan-v2/scripts/run_baseline.mjs --aggregate-only",
    "benchmark:v2:score": "node benchmarks/qa-plan-v2/scripts/score_iteration.mjs"
  }
}
