# LLM API config for benchmark runner/grader
# Copy this to .env and fill in your key.
# .env is gitignored; .env.example is committed.

# --- Provider (set exactly one) ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Base URL override (optional) ---
# Point to any OpenAI-compatible endpoint: Azure OpenAI, Ollama, LiteLLM, etc.
# When set, all providers use /v1/chat/completions against this URL.
# LLM_API_BASE_URL=http://localhost:11434
# Example (GMNCODE):
# LLM_API_BASE_URL=https://gmncode.cn

# --- Tuning (optional) ---
# BENCHMARK_LLM_MODEL=gpt-4o
# BENCHMARK_LLM_MAX_TOKENS=16384
# Example (GMNCODE model):
# BENCHMARK_LLM_MODEL=gpt-5.2
