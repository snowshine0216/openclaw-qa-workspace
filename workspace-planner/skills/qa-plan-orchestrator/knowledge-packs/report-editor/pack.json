    },
    {
      "id": "outcome-i18n-dialog",
      "keywords": [
        "i18n dialogs",
        "save dialog completeness and interactivity"
      ],
      "observable_outcome": "localized dialog actions remain complete and interactive"
    },
    {
      "id": "outcome-report-builder-prompt-load",
      "keywords": [
        "report builder interaction",
        "prompt execution",
        "double-click"
      ],
      "observable_outcome": "report builder loads prompt elements correctly after double-click"
    },
    {
      "id": "outcome-edit-report-title",
      "keywords": [
        "window title correctness",
        "edit report",
        "workstation"
      ],
      "observable_outcome": "edit report in workstation shows the correct title matching the current report"
    },
    {
      "id": "outcome-save-as-overwrite-no-crash",
      "keywords": [
        "save-as-overwrite",
        "save override",
        "JS error"
      ],
      "observable_outcome": "save-as to overwrite existing report completes without JS error"
    },
    {
      "id": "outcome-i18n-all-dialogs",
      "keywords": [
        "i18n dialogs",
        "productstrings",
        "locale"
      ],
      "observable_outcome": "all dialog string keys added or changed in the release are translated for all supported locales"
    }
  ],
  "state_transitions": [
    {
      "id": "transition-template-draft-to-saved",
      "from": "template-based creation",
      "to": "save override",
      "trigger": "save action",
      "observable_outcome": "folder visibility refresh after save"
    },
    {
      "id": "transition-prompt-editor-close-confirmation",
      "from": "prompt editor open",
      "to": "close-confirmation",
      "trigger": "close action",
      "observable_outcome": "pause-mode prompts and confirmation path are explicit"
    },
    {
      "id": "transition-save-as-overwrite-conflict",
      "from": "save-as initiated",
      "to": "overwrite-confirmation",
      "trigger": "target report already exists",
      "observable_outcome": "overwrite confirmation shown without JS error; existing report replaced on confirm"
    },
    {
      "id": "transition-prompt-pause-mode-template-run",
      "from": "template-based creation with prompt pause mode",
      "to": "report running",
      "trigger": "template saved and opened",
      "observable_outcome": "report with prompt pause mode runs correctly after template creation"
    },
    {
      "id": "transition-double-click-edit-title",
      "from": "report list view",
      "to": "edit report open",
      "trigger": "double-click on report in workstation",
      "observable_outcome": "editor opens with the correct report title (not stale/wrong title)"
    }
  ],
