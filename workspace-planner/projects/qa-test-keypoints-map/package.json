{
  "name": "qa-test-keypoints-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "FQPO_RUNS_ROOT=\"$(cd ../../.. && pwd)/workspace-planner/skills/qa-plan-orchestrator/runs\" tsx watch src/server/index.ts",
    "start:client": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "start:server": "FQPO_RUNS_ROOT=\"$(cd ../../.. && pwd)/workspace-planner/skills/qa-plan-orchestrator/runs\" PORT=4174 tsx src/server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "validate": "FQPO_RUNS_ROOT=\"$(cd ../../.. && pwd)/workspace-planner/skills/qa-plan-orchestrator/runs\" tsx src/server/reportCli.ts validate",
    "report": "FQPO_RUNS_ROOT=\"$(cd ../../.. && pwd)/workspace-planner/skills/qa-plan-orchestrator/runs\" tsx src/server/reportCli.ts report",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.2",
    "dagre": "^0.8.5",
    "express": "^4.21.2",
    "mdast-util-to-markdown": "^2.1.2",
    "mdast-util-to-string": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@playwright/test": "^1.52.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
