{
  "name": "rca-daily",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "bash src/tests/run-integration-tests.sh"
  },
  "devDependencies": {
    "jest": "^30.2.0"
  },
  "jest": {
    "testMatch": ["**/tests/unit/**/*.test.js"],
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"]
  }
}
