# Environment & Secrets
.env
.env.*
!.env.example
*.secret
*.key

# OpenClaw Secrets & State
**/.openclaw/
**/*auth.json
**/*token*.json
**/credentials/

# Memory Files (may contain sensitive context)
**/memory/*.md
!**/memory/.gitkeep

# Site knowledge (generated, excluded from version control)
workspace-tester/memory/site-knowledge/

# Tester-flow runtime state (runs, logs, healing reports)
workspace-tester/memory/tester-flow/

# Logs & Temp Files
*.log
*.tmp
.DS_Store
Thumbs.db

# Node modules (if any scripts need them)
node_modules/
package-lock.json

# Build outputs (regenerated by npm run build)
workspace-planner/projects/qa-test-keypoints-map/dist/
workspace-planner/projects/qa-test-keypoints-map/playwright-report/
workspace-planner/projects/qa-test-keypoints-map/test-results/

# Backup files
*.bak
*~

# Eval workspaces (skill-creator run outputs)
**/*-workspace/

# Design review outputs (generated by openclaw-agent-design-review)
projects/agent-design-review/

#Reports folders
tmp/
report/
reports/
temp/
data/
defects-analysis/
!workspace-reporter/skills/defects-analysis/
!workspace-reporter/skills/defects-analysis/**
qa-summaries/
feature-plan/
test-reports/
screenshots/
test-cases/
output/
run/
runs/
test-plans/
workspace-planner/projects/test-plans/
