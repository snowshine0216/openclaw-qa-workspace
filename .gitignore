# Environment & Secrets
.env
.env.*
*.secret
*.key

# OpenClaw Secrets & State
**/.openclaw/
**/*auth.json
**/*token*.json
**/credentials/

# Memory Files (may contain sensitive context)
**/memory/*.md
!**/memory/.gitkeep

# Logs & Temp Files
*.log
*.tmp
.DS_Store
Thumbs.db

# Node modules (if any scripts need them)
node_modules/
package-lock.json

# Build outputs (regenerated by npm run build)
workspace-planner/projects/qa-test-keypoints-map/dist/

# Backup files
*.bak
*~

